# DisGenerator Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Model Configuration
# ============================================
MODEL_NAME=arcee-ai/Trinity-Mini
LORA_ADAPTER_PATH=../DisTrainer/policies/policy-0-initial
LORA_ADAPTER_NAME=trinity-reasoning-vllm

# ============================================
# Disaggregated Server Configuration
# ============================================
PREFILL_HOST=localhost
PREFILL_PORT=8100
DECODE_HOST=localhost
DECODE_PORT=8200

# ============================================
# Generation Parameters (Orchestrator Hyperparameters)
# ============================================
BATCH_SIZE=10                        # Number of prompts per batch file (10 prompts × 4 completions = 40 trajectories)
NUM_COMPLETIONS=4                    # Completions per prompt (GRPO group size)
GENERATION_TEMPERATURE=0.9           # Temperature for diverse completions
MAX_TOKENS_PER_COMPLETION=4096       # Max tokens per completion
MAX_TURNS=8                          # Max tool-use turns per trajectory

# ============================================
# Azure Service Bus Configuration
# ============================================
# Get these values from Azure Portal > Service Bus Namespace > Shared access policies
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://YOUR_NAMESPACE.servicebus.windows.net/;SharedAccessKeyName=YOUR_POLICY;SharedAccessKey=YOUR_KEY
COMMAND_TOPIC_NAME=commandtopic
REWARD_TOPIC_NAME=rewardtopic
WEB_SUBSCRIPTION_NAME=websubscription
CODE_SUBSCRIPTION_NAME=codesubscription
GRADER_SUBSCRIPTION_NAME=gradersubscription
GRADER_REWARD_SUBSCRIPTION_NAME=webrewardsubscription

# ============================================
# Timeouts
# ============================================
TOOL_TIMEOUT_S=30
GRADER_TIMEOUT_S=60
REQUEST_TIMEOUT_S=120

# ============================================
# Output Configuration
# ============================================
OUTPUT_DIR=../DisTrainer/data/generations
BATCHES_PER_FILE=1

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
DEBUG=0

# ============================================
# System Prompt (Matches ToolGRPOTrainer)
# ============================================
SYSTEM_PROMPT="You are an ORCHESTRATOR/CODING AGENT. Complete real tasks by calling tools and then returning a concise final solution.\n\nRULES\n- Always start every answer with <think>...</think>.\n- Allowed tags: <think>, <web>, <code>, <azure>, <solution>.\n- Tool calls must be a strict JSON object inside the tag:\n  • <web>{\"type\":\"web\",\"q\":\"search terms\",\"k\":INT}</web>\n  • <code>{\"type\":\"code\",\"code_command\":\"shell command\"}</code>\n  • <azure>{\"type\":\"azure\",\"azure_command\":\"az subcommand\"}</azure>\n- No extra keys, metadata, or comments. Double quotes only.\n- One tool call per turn. Do not mix tools.\n- After each tool call, STOP and wait for the <tool_result> from the system.\n- Do NOT generate your own <tool_result> - the system will provide real results.\n- Prefer tools over guessing; use official docs when unsure.\n- Verify after every action (e.g. check files, confirm Azure state).\n- Stop with a single <solution> once the task is complete.\n\nEXAMPLE TURN 1:\n<think>User wants a FastAPI signup endpoint. I'll first check docs.</think>\n<web>{\"type\":\"web\",\"q\":\"FastAPI POST endpoint\",\"k\":3}</web>\n\nEXAMPLE TURN 2 (after system provides tool_result):\n<think>Good, I found the pattern. Now creating the file.</think>\n<code>{\"type\":\"code\",\"code_command\":\"cat > app.py << 'EOF'\nfrom fastapi import FastAPI\napp = FastAPI()\nEOF\"}</code>\n\nEXAMPLE FINAL TURN:\n<solution>FastAPI service created and verified.</solution>"
