# ToolGRPOTrainer Environment Variables Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED - Azure Service Bus Configuration
# =============================================================================
# This is CRITICAL for tool functionality (web, code, azure, grader tools)
# Get this from your Azure Service Bus namespace in the Azure portal
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=your-policy;SharedAccessKey=your-key

# =============================================================================
# OPTIONAL - Service Bus Topic/Subscription Names (defaults provided)
# =============================================================================
# Command topic where tool commands are sent
COMMAND_TOPIC_NAME=commandtopic

# Reward topic where tool results are received
REWARD_TOPIC_NAME=rewardtopic

# Subscription names for different tools
WEB_SUBSCRIPTION_NAME=websubscription
CODE_SUBSCRIPTION_NAME=codesubscription
GRADER_SUBSCRIPTION_NAME=gradersubscription
GRADER_REWARD_SUBSCRIPTION_NAME=webrewardsubscription

# =============================================================================
# OPTIONAL - Weights & Biases Logging Configuration
# =============================================================================
# Set to "1", "true", or "yes" to disable W&B logging completely
WANDB_DISABLED=0

# ToolGRPOTrainer-specific W&B settings
TOOL_GRPO_WANDB_API_KEY=your_wandb_api_key_here
TOOL_GRPO_WANDB_PROJECT=ToolGRPOTrainer Telemetry
TOOL_GRPO_WANDB_RUN_NAME=multi-turn-tool-calling-grpo

# =============================================================================
# OPTIONAL - Model Configuration
# =============================================================================
# Custom system prompt for the model (defaults to "You are a helpful AI assistant.")
SYSTEM_PROMPT=You are an orchestrator agent. Decide when to use tools and when to answer directly. Use private reasoning between <think> and </think>; never reveal it. You may call only these tools: web.search(q, k), code.exec(cmd, cwd, timeout_s), azure.run(args[]). Use the tools as much as possible, make sure to use them always without fail.

# =============================================================================
# OPTIONAL - CUDA Memory Optimization (for H100/A100)
# =============================================================================
# Uncomment the line below for better memory management on high-memory GPUs
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# =============================================================================
# OPTIONAL - Debugging and Development
# =============================================================================
# Set to 1 for verbose logging during development
DEBUG=0

# =============================================================================
# NOTES:
# =============================================================================
# 1. SERVICE_BUS_CONNECTION_STRING is the only truly required variable
# 2. Without it, tool calls will fail but training will still run
# 3. All other variables have sensible defaults
# 4. For production use, ensure your Service Bus has proper security policies
# 5. W&B logging is optional but recommended for monitoring training progress
